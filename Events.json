{
  "Events": [
    {
      "EventName": "Session Started",
      "Enabled": false,
      "Rule": "SessionNameChangedToActive",
      "RuleSettings": {}
    },
    {
      "EventName": "Session Stopped",
      "Enabled": false,
      "Rule": "SessionNameChangedPreviousSessionEnded",
      "RuleSettings": {}
    },
    {
      "EventName": "Position Changed",
      "Enabled": false,
      "Rule": "CurrentPositionDifferentFromPreviousSample",
      "RuleSettings": {}
    },
    {
      "EventName": "Fastest Lap",
      "Enabled": false,
      "Rule": "PersonalBestOrGlobalBestImprovedOnLapChange",
      "RuleSettings": {
        "PersonalBestEnabled": true,
        "GlobalBestEnabled": true,
        "GlobalBestLapTimePropertyKeys": [
          "GlobalFastestLapTime",
          "OverallBestLapTime",
          "SessionFastestLapTime",
          "FastestLapTime"
        ]
      }
    },
    {
      "EventName": "Entering Pits",
      "Enabled": true,
      "Rule": "InPitFlagTransitionFalseToTrue",
      "RuleSettings": {
        "PitPropertyKeys": [
          "InPitLane",
          "InPit"
        ]
      }
    },
    {
      "EventName": "Exiting Pits",
      "Enabled": true,
      "Rule": "InPitFlagTransitionTrueToFalse",
      "RuleSettings": {
        "PitPropertyKeys": [
          "InPitLane",
          "InPit"
        ]
      }
    },
    {
      "EventName": "Bad lap",
      "Enabled": false,
      "Rule": "LapDeltaThresholdOrIncidentProxyOnLapChange",
      "RuleSettings": {
        "DeltaThresholdSeconds": 5.0,
        "IncidentFlagPropertyKeys": [
          "Incident",
          "HasIncident",
          "IncidentDetected",
          "IsOffTrack",
          "OffTrack"
        ]
      }
    },
    {
      "EventName": "Qualification Started",
      "Enabled": true,
      "Rule": "SessionNameChangedToQualification",
      "RuleSettings": {
        "QualificationSessionNames": [
          "Qualify",
          "Qualification",
          "Lone Qualify"
        ]
      }
    },
    {
      "EventName": "Race Started",
      "Enabled": true,
      "Rule": "SessionNameChangedToRace",
      "RuleSettings": {
        "RaceSessionNames": [
          "Race"
        ]
      }
    },
    {
      "EventName": "Qualification Complete",
      "Enabled": true,
      "Rule": "SessionNameChangedFromQualification",
      "RuleSettings": {
        "QualificationSessionNames": [
          "Qualify",
          "Qualification",
          "Lone Qualify"
        ]
      }
    },
    {
      "EventName": "Race Complete",
      "Enabled": true,
      "Rule": "SessionNameChangedFromRace",
      "RuleSettings": {
        "RaceSessionNames": [
          "Race"
        ]
      }
    },
    {
      "EventName": "Fuel Warning",
      "Enabled": true,
      "Rule": "FuelLevelBelowThreshold",
      "RuleSettings": {
        "MinimumRemainingLaps": 3.0,
        "MinimumRemainingTimeSeconds": 300.0,
        "FuelRemainingLapsPropertyKeys": [
          "Fuel_RemainingLaps"
        ],
        "FuelRemainingTimePropertyKeys": [
          "Fuel_RemainingTime"
        ]
      }
    }
  ]
}
