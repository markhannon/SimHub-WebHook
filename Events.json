{
  "Events": [
    {
      "EventName": "Session Started",
      "ShortName": "SESSION STARTED",
      "IncludeEventDetailsText": false,
      "IncludeSessionSummaryInEventDetails": true,
      "IncludeGameSummaryInEventDetails": true,
      "Enabled": false,
      "Rule": "SessionNameChangedToActive",
      "RuleSettings": {}
    },
    {
      "EventName": "Session Stopped",
      "ShortName": "SESSION STOPPED",
      "IncludeEventDetailsText": false,
      "IncludeSessionSummaryInEventDetails": true,
      "IncludeGameSummaryInEventDetails": true,
      "Enabled": false,
      "Rule": "SessionNameChangedPreviousSessionEnded",
      "RuleSettings": {}
    },
    {
      "EventName": "Position Changed",
      "ShortName": "POSITION CHANGED",
      "IncludeEventDetailsText": false,
      "IncludeSessionSummaryInEventDetails": true,
      "IncludeGameSummaryInEventDetails": false,
      "Enabled": false,
      "Rule": "CurrentPositionDifferentFromPreviousSample",
      "RuleSettings": {}
    },
    {
      "EventName": "Fastest Lap",
      "ShortName": "FASTEST LAP",
      "IncludeEventDetailsText": false,
      "IncludeSessionSummaryInEventDetails": true,
      "IncludeGameSummaryInEventDetails": false,
      "Enabled": false,
      "Rule": "PersonalBestOrGlobalBestImprovedOnLapChange",
      "RuleSettings": {
        "PersonalBestEnabled": true,
        "GlobalBestEnabled": true,
        "GlobalBestLapTimePropertyKeys": [
          "GlobalFastestLapTime",
          "OverallBestLapTime",
          "SessionFastestLapTime",
          "FastestLapTime"
        ]
      }
    },
    {
      "EventName": "Entering Pits",
      "ShortName": "PIT IN",
      "IncludeEventDetailsText": false,
      "IncludeSessionSummaryInEventDetails": true,
      "IncludeGameSummaryInEventDetails": false,
      "Enabled": true,
      "Rule": "InPitFlagTransitionFalseToTrue",
      "RuleSettings": {
        "PitPropertyKeys": [
          "DataCorePlugin.GameData.IsInPitLane",
          "DataCorePlugin.GameData.IsInPit"
        ]
      }
    },
    {
      "EventName": "Exiting Pits",
      "ShortName": "PIT OUT",
      "IncludeEventDetailsText": false,
      "IncludeSessionSummaryInEventDetails": true,
      "IncludeGameSummaryInEventDetails": false,
      "Enabled": true,
      "Rule": "InPitFlagTransitionTrueToFalse",
      "RuleSettings": {
        "PitPropertyKeys": [
          "DataCorePlugin.GameData.IsInPitLane",
          "DataCorePlugin.GameData.IsInPit"
        ]
      }
    },
    {
      "EventName": "Driver Change",
      "ShortName": "DRIVER CHANGE",
      "IncludeEventDetailsText": true,
      "IncludeSessionSummaryInEventDetails": true,
      "IncludeGameSummaryInEventDetails": true,
      "Enabled": true,
      "Rule": "DriverNameChangedWhileInPit",
      "RuleSettings": {}
    },
    {
      "EventName": "Bad lap",
      "ShortName": "BAD LAP",
      "IncludeEventDetailsText": false,
      "IncludeSessionSummaryInEventDetails": true,
      "IncludeGameSummaryInEventDetails": false,
      "Enabled": false,
      "Rule": "LapDeltaThresholdOrIncidentProxyOnLapChange",
      "RuleSettings": {
        "DeltaThresholdSeconds": 5.0,
        "IncidentFlagPropertyKeys": [
          "Incident",
          "HasIncident",
          "IncidentDetected",
          "IsOffTrack",
          "OffTrack"
        ]
      }
    },
    {
      "EventName": "Qualification Started",
      "ShortName": "QUAL STARTED",
      "IncludeEventDetailsText": false,
      "IncludeSessionSummaryInEventDetails": false,
      "IncludeGameSummaryInEventDetails": true,
      "Enabled": true,
      "Rule": "SessionNameChangedToQualification",
      "RuleSettings": {
        "QualificationSessionNames": [
          "Qualify",
          "Qualification",
          "Lone Qualify"
        ]
      }
    },
    {
      "EventName": "Race Started",
      "ShortName": "RACE STARTED",
      "IncludeEventDetailsText": false,
      "IncludeSessionSummaryInEventDetails": false,
      "IncludeGameSummaryInEventDetails": true,
      "Enabled": true,
      "Rule": "SessionNameChangedToRace",
      "RuleSettings": {
        "RaceSessionNames": [
          "Race"
        ]
      }
    },
    {
      "EventName": "Qualification Complete",
      "ShortName": "QUAL COMPLETE",
      "IncludeEventDetailsText": false,
      "IncludeSessionSummaryInEventDetails": false,
      "IncludeGameSummaryInEventDetails": true,
      "Enabled": true,
      "Rule": "SessionNameChangedFromQualification",
      "RuleSettings": {
        "QualificationSessionNames": [
          "Qualify",
          "Qualification",
          "Lone Qualify"
        ]
      }
    },
    {
      "EventName": "Race Complete",
      "ShortName": "RACE COMPLETE",
      "IncludeEventDetailsText": false,
      "IncludeSessionSummaryInEventDetails": false,
      "IncludeGameSummaryInEventDetails": true,
      "Enabled": true,
      "Rule": "SessionNameChangedFromRace",
      "RuleSettings": {
        "RaceSessionNames": [
          "Race"
        ]
      }
    },
    {
      "EventName": "Fuel Warning",
      "ShortName": "FUEL WARNING",
      "IncludeEventDetailsText": true,
      "IncludeSessionSummaryInEventDetails": true,
      "IncludeGameSummaryInEventDetails": false,
      "Enabled": true,
      "Rule": "FuelLevelBelowThreshold",
      "RuleSettings": {
        "MinimumRemainingLaps": 3.0,
        "MinimumRemainingTimeSeconds": 300.0,
        "FuelRemainingLapsPropertyKeys": [
          "Fuel_RemainingLaps"
        ],
        "FuelRemainingTimePropertyKeys": [
          "Fuel_RemainingTime"
        ]
      }
    },
    {
      "EventName": "Pit Stop Detected",
      "ShortName": "PIT IN",
      "IncludeEventDetailsText": false,
      "IncludeSessionSummaryInEventDetails": true,
      "IncludeGameSummaryInEventDetails": false,
      "Enabled": false,
      "Rule": "InferredFromRefuelOrStopDuration",
      "RuleSettings": {
        "FuelRefillThresholdLiters": 2.0,
        "FuelPropertyKeys": [
          "Fuel"
        ],
        "LastPitStopDurationPropertyKeys": [
          "LastPitStopDuration",
          "DataCorePlugin.GameData.LastPitStopDuration"
        ]
      }
    }
  ]
}
